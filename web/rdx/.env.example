# URL of the Redtonomous FastAPI backend (same backend as Chat UI)
# Leave empty to use localhost:8000 (local dev)
# Set to your deployed backend for production (Railway, Render, Fly.io, etc.)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional bearer token — required if the FastAPI backend was started with
# REDTONOMOUS_API_TOKEN set. Leave blank for open-dev mode.
NEXT_PUBLIC_API_TOKEN=
